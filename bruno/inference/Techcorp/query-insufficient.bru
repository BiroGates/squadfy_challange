meta {
  name: Query — Insufficient Knowledge
  type: http
  seq: 2
}

post {
  url: {{base_url}}/inference/query
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "query": "What is the best recipe for chocolate cake?"
  }
  
  
}

docs {
  # Query — Insufficient Knowledge
  Pergunta sobre algo completamente fora da base de conhecimento da organização.
  Expected responseType: "INSUFFICIENT"
  O LLM decide que nenhum documento recuperado é relevante para responder.
  Required role: USER | ORGANIZATION | ADMIN
}
