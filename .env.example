DATABASE_URL=postgres://postgres:postgres@localhost:5432/knowledge_base

KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

GOOGLE_API_KEY=your-google-ai-studio-key

# Delay (ms) before each LLM call — respects Gemini free-tier 15 RPM limit.
# Set to 0 on a paid plan.
LLM_CALL_DELAY_MS=4500

# Local development: use MinIO (started via docker compose)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000     # remove this line to use real AWS S3
S3_BUCKET_NAME=squadfy-knowledge

PORT=3000
